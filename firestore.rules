rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && request.auth.token.email == "thanhnt.ads@gmail.com")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection - user can read their own if it exists
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable through console or seed
    }

    // Generic rule for manageable content: Everyone can read, only Admins can write
    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /collection_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /project_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /news_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /contact/info {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
