{
  "entities": {
    "Setting": {
      "title": "Setting",
      "description": "Global or specific section settings",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "section2Bg": { "type": "string" },
        "section3Bg": { "type": "string" },
        "section4Bg": { "type": "string" },
        "section5Bg": { "type": "string" },
        "section6Bg": { "type": "string" },
        "videoUrl": { "type": "string" },
        "links": { "type": "array" }
      }
    },
    "HeroSlide": {
      "title": "Hero Slide",
      "description": "Slide for the hero section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "CollectionSlide": {
      "title": "Collection Slide",
      "description": "Slide for building/project collections",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "ProjectSlide": {
      "title": "Project Slide",
      "description": "Slide for featured projects/products",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "NewsItem": {
      "title": "News Item",
      "description": "News article or update",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "ContactInfo": {
      "title": "Contact Info",
      "description": "Business contact details",
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "mapUrl": { "type": "string" },
        "facebook": { "type": "string" },
        "youtube": { "type": "string" },
        "zalo": { "type": "string" }
      }
    },
    "CompanyPage": {
      "title": "Company Page",
      "description": "Content for About/Company page",
      "type": "object",
      "properties": {
        "hero_image": { "type": "string" },
        "hero_title": { "type": "string" },
        "intro_vocation_text": { "type": "string" },
        "intro_design_activity_text": { "type": "string" },
        "intro_cta1": { "type": "string" },
        "intro_cta2": { "type": "string" },
        "section1_image": { "type": "string" },
        "section1_title": { "type": "string" },
        "section1_description": { "type": "string" },
        "section2_image": { "type": "string" },
        "section2_title": { "type": "string" },
        "section2_description": { "type": "string" },
        "video_placeholder_image": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Product item for the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specs": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "FooterSettings": {
      "title": "Footer Settings",
      "description": "Configuration for the website footer",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "description": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "zaloUrl": { "type": "string" },
        "copyright": { "type": "string" },
        "quickLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "servicesLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "CollectionsPage": {
      "title": "Collections Page",
      "description": "Full content for the collections page",
      "type": "object",
      "properties": {
        "hero_title": { "type": "string" },
        "hero_image": { "type": "string" },
        "explore": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "buttonText": { "type": "string" },
            "image": { "type": "string" }
          }
        },
        "featured": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "buttonText": { "type": "string" },
            "slides": { "type": "array" }
          }
        },
        "research": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "videoUrl": { "type": "string" }
          }
        },
        "news": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "buttonText": { "type": "string" }
          }
        },
        "architectural_solutions": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "buttonText": { "type": "string" },
            "slides": { "type": "array" }
          }
        },
        "architectural_space": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "buttonText": { "type": "string" },
            "slides": { "type": "array" }
          }
        },
        "inspiration": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "buttonText": { "type": "string" },
            "topImages": { "type": "array" },
            "bottomCards": { "type": "array" }
          }
        }
      }
    },
    "Admin": {
      "title": "Admin",
      "description": "Authorized admin users",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "authorized": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "Global and hero settings"
    },
    "hero_slides/{slideId}": {
      "schema": "HeroSlide",
      "description": "Slides for the hero section"
    },
    "collection_slides/{slideId}": {
      "schema": "CollectionSlide",
      "description": "Building/project collections"
    },
    "project_slides/{slideId}": {
      "schema": "ProjectSlide",
      "description": "Featured projects/products on home"
    },
    "news_items/{newsId}": {
      "schema": "NewsItem",
      "description": "News articles"
    },
    "contact/info": {
      "schema": "ContactInfo",
      "description": "Contact details"
    },
    "cms/company_page": {
      "schema": "CompanyPage",
      "description": "About page content"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Product catalogue"
    },
    "admins/{userId}": {
      "schema": "Admin",
      "description": "Admin authorization list"
    }
  }
}
