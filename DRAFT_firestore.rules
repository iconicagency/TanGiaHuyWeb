rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.authorized == true) ||
             (request.auth.token.email == "thanhnt.ads@gmail.com") ||
             (request.auth.token.email == "hyperlinkec@gmail.com");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidSetting(data) {
      return data.keys().hasAny(['logoUrl', 'section2Bg', 'section3Bg', 'section4Bg', 'section5Bg', 'section6Bg', 'videoUrl', 'links']) &&
             (data.get('logoUrl', '') is string) &&
             (data.get('videoUrl', '') is string);
    }

    function isValidSlide(data) {
      return data.keys().hasAll(['title', 'image', 'order']) &&
             data.title is string && data.title.size() <= 200 &&
             data.image is string && data.image.size() <= 1000 &&
             data.order is number;
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'image', 'date']) &&
             data.title is string && data.title.size() <= 300 &&
             data.image is string && data.image.size() <= 1000;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'image']) &&
             data.name is string && data.name.size() <= 200 &&
             data.image is string && data.image.size() <= 1000;
    }

    function isValidContact(data) {
      return data.get('email', '') is string && data.get('phone', '') is string;
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'authorized']) &&
             data.email is string && data.authorized is bool;
    }

    // --- Rules ---

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSetting(incoming());
    }

    // Hero Slides
    match /hero_slides/{slideId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSlide(incoming());
      allow delete: if isAdmin();
    }

    // Collection Slides
    match /collection_slides/{slideId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSlide(incoming());
      allow delete: if isAdmin();
    }

    // Project Slides
    match /project_slides/{slideId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSlide(incoming());
      allow delete: if isAdmin();
    }

    // News Items
    match /news_items/{newsId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidNews(incoming());
      allow delete: if isAdmin();
    }

    // Contact Info
    match /contact/info {
      allow read: if true;
      allow write: if isAdmin() && isValidContact(incoming());
    }

    // Company Page Content
    match /cms/company_page {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Admins
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId && !exists(/databases/$(database)/documents/admins/$(userId)));
    }
  }
}
