rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && request.auth.token.email == "thanhnt.ads@gmail.com")
      );
    }

    function isBootstrapAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == "thanhnt.ads@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation Helpers
    function isValidHeroSlide(data) {
      return data.keys().hasAll(['title', 'order', 'image']) &&
             data.title is string && data.title.size() < 200 &&
             data.image is string && data.image.size() < 1000 &&
             data.order is int;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['videoUrl']) &&
             data.videoUrl is string && data.videoUrl.size() < 1000;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Public Collections - Read for all, Write for Admin
    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin() && (slideId == 'new' || isValidHeroSlide(incoming()));
    }
    
    match /collection_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /project_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /news_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /contact/info {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    // Admin identities
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isBootstrapAdmin() && request.auth.uid == userId;
    }
  }
}
