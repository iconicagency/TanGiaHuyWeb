{
  "entities": {
    "CompanyContent": {
      "title": "Company Page Content",
      "description": "Content for the Company page",
      "type": "object",
      "properties": {
        "hero_image": { "type": "string", "format": "uri" },
        "hero_title": { "type": "string" },
        "section1_image": { "type": "string", "format": "uri" },
        "section1_title": { "type": "string" },
        "section1_description": { "type": "string" },
        "section2_image": { "type": "string", "format": "uri" },
        "section2_title": { "type": "string" },
        "section2_description": { "type": "string" },
        "video_placeholder_image": { "type": "string", "format": "uri" }
      },
      "required": ["hero_title", "section1_title", "section2_title"]
    },
    "NavLink": {
      "title": "Navigation Link",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "href": { "type": "string" },
        "desc": { "type": "string" }
      },
      "required": ["name", "href"]
    },
    "NavigationSettings": {
      "title": "Navigation Settings",
      "description": "Main menu navigation links",
      "type": "object",
      "properties": {
        "links": {
          "type": "array",
          "items": { "$ref": "NavLink" }
        }
      },
      "required": ["links"]
    }
  },
  "firestore": {
    "/cms/company_page": {
      "schema": "CompanyContent",
      "description": "Content for the About Us page"
    },
    "/settings/navigation": {
      "schema": "NavigationSettings",
      "description": "Main header navigation menu"
    }
  }
}
